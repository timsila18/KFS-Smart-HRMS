APP_NAME="KFS Smart HRMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
LOG_DAILY_DAYS=14

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kfs_smart_hrms
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer
DB_URL=

SESSION_DRIVER=file
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_EXPIRE_ON_CLOSE=false

CACHE_STORE=database
QUEUE_CONNECTION=database
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids
MAIL_MAILER=log

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

KFS_AUTH_SESSION_TIMEOUT_MINUTES=30
KFS_AUTH_TWO_FACTOR_ENABLED=false
KFS_AUTH_ALLOWED_LOGIN_ROLES=super-admin,hr-admin,hr-manager,hr-payroll-operator,hr-director,hr-officer,payroll-manager,station-manager,employee
KFS_SEED_HR_ADMIN_EMAIL=hr.admin@kfs.go.ke
KFS_SEED_HR_ADMIN_PASSWORD=KfsAdmin@2026
KFS_SEED_HR_MANAGER_EMAIL=hr.manager@kfs.go.ke
KFS_SEED_HR_MANAGER_PASSWORD=KfsManager@2026
KFS_SEED_HR_PAYROLL_OPERATOR_EMAIL=payroll.operator@kfs.go.ke
KFS_SEED_HR_PAYROLL_OPERATOR_PASSWORD=KfsPayroll@2026
KFS_DASHBOARD_CONTRACT_EXPIRY_WINDOW_DAYS=90
KFS_DASHBOARD_SUMMARY_CACHE_SECONDS=300
KFS_API_RATE_LIMIT_PER_MINUTE=120
PAYROLL_NSSF_MONTHLY_AMOUNT=1080.000000000000000000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_EXPIRATION_MINUTES=480

SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=()"
SECURITY_CONTENT_SECURITY_POLICY="default-src 'self'; img-src 'self' data: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
