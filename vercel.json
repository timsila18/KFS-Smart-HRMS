{
  "version": 2,
  "buildCommand": "composer install --no-dev --prefer-dist --no-interaction --no-progress --no-scripts --optimize-autoloader && npm install && npm run build && php artisan package:discover --ansi",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://kfs-smart-hrms.vercel.app",
    "LOG_CHANNEL": "stderr",
    "CACHE_STORE": "database",
    "SESSION_DRIVER": "database",
    "SESSION_TABLE": "app_sessions",
    "QUEUE_CONNECTION": "sync",
    "VIEW_COMPILED_PATH": "/tmp/kfs-smart-hrms/framework/views",
    "APP_STORAGE_PATH": "/tmp/kfs-smart-hrms"
  }
}
